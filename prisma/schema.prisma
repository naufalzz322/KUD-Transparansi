generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  role      UserRole
  password  String
  settlements MonthlySettlement[] @relation("ProcessedBy")
  auditLogs AuditLog[]
  pushSubscriptions PushSubscription[]
  notifications Notification[]
  createdAt DateTime  @default(now())
}

enum UserRole {
  ADMIN
}

model Member {
  id            String         @id @default(cuid())
  memberNumber  String         @unique
  name          String
  phone         String
  email         String?        @unique
  portalToken   String         @unique @default(cuid())
  portalPin     String         // bcrypt hash
  qrCodeData    String?        // Base64 QR code image for WhatsApp
  joinDate      DateTime
  isActive      Boolean        @default(true)
  address       String?
  notificationPrefs Json        @default("{\"whatsapp\": true, \"email\": true, \"sms\": false}")
  stockBatches StockBatch[]   @relation("DepositedBy")
  settlements   MonthlySettlement[]
  pushSubscriptions PushSubscription[]
  notifications Notification[]
  memberProducts MemberProduct[]
  createdAt     DateTime       @default(now())
}

model StockItem {
  id            String         @id @default(cuid())
  name          String         @unique
  category      StockCategory  @default(LAINNYA)
  defaultUnit   String         @default("liter") // liter, kg, pcs, gram, etc.
  shelfLifeDays Int            @default(3)       // Default shelf life in days
  priceGradeA   Decimal?       @db.Decimal(10, 2) // Price per unit for Grade A
  priceGradeB   Decimal?       @db.Decimal(10, 2) // Price per unit for Grade B
  isActive      Boolean        @default(true)
  note          String?
  stockBatches  StockBatch[]
  memberProducts MemberProduct[]
  settlementDetails SettlementDetail[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum Grade {
  A
  B
}

enum StockCategory {
  MINUMAN       // Beverages (milk, juice, etc.)
  SAYURAN       // Vegetables
  BUAH          // Fruits
  LAINNYA       // Others
}

model StockBatch {
  id            String      @id @default(cuid())
  stockItemId   String
  stockItem     StockItem   @relation(fields: [stockItemId], references: [id])
  memberId      String?     // Nullable - for non-member transactions
  member        Member?     @relation("DepositedBy", fields: [memberId], references: [id])
  type          StockType   @default(DEPOSIT)
  qty           Decimal     @db.Decimal(10, 2)
  unit          String      // Inherits from StockItem or can be overridden
  grade         Grade?      // null if not graded
  receivedDate  DateTime    @db.Date  // When the item was received/deposited
  expiryDate    DateTime    @db.Date  // Calculated: receivedDate + shelfLifeDays
  status        StockStatus @default(OK)
  notes         String?
  createdAt     DateTime    @default(now())

  @@index([stockItemId])
  @@index([memberId])
  @@index([receivedDate])
  @@index([expiryDate])
  @@index([status])
}

enum StockType {
  DEPOSIT      // From member
  PURCHASE     // External purchase
  ADJUSTMENT   // Manual adjustment
}

enum StockStatus {
  OK
  WARNING      // 1 day before expiry
  CRITICAL     // Same day as expiry
  EXPIRED      // Past expiry
}

model MonthlySettlement {
  id              String    @id @default(cuid())
  memberId        String
  member          Member    @relation(fields: [memberId], references: [id])
  period          String    // YYYY-MM format
  totalQty        Decimal   @db.Decimal(10, 2)
  gradeAQty       Decimal   @db.Decimal(10, 2)
  gradeBQty       Decimal   @db.Decimal(10, 2)
  totalPayment    Decimal   @db.Decimal(12, 2)
  paidAmount      Decimal   @db.Decimal(12, 2) @default(0) // Track partial payments
  status          SettlementStatus @default(PENDING)
  processedById   String
  processedBy     User      @relation("ProcessedBy", fields: [processedById], references: [id])
  processedAt     DateTime?
  paidAt          DateTime?
  notes           String?
  details         SettlementDetail[]
  createdAt       DateTime  @default(now())

  @@unique([memberId, period])
}

// Per-product breakdown for settlements
model SettlementDetail {
  id            String   @id @default(cuid())
  settlementId  String
  settlement    MonthlySettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  stockItemId   String
  stockItem     StockItem @relation(fields: [stockItemId], references: [id])
  gradeAQty     Decimal  @db.Decimal(10, 2)
  gradeBQty     Decimal  @db.Decimal(10, 2)
  priceGradeA   Decimal  @db.Decimal(10, 2)
  priceGradeB   Decimal  @db.Decimal(10, 2)
  paymentA      Decimal  @db.Decimal(12, 2)
  paymentB      Decimal  @db.Decimal(12, 2)
  totalPayment  Decimal  @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  @@index([settlementId])
}

enum SettlementStatus {
  PENDING
  PARSIAL
  PAID
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  action      String   // CREATE, UPDATE, DELETE, VIEW, EXPORT, LOGIN, LOGOUT
  entityType  String   // Member, StockBatch, Settlement, etc.
  entityId    String?
  details     Json     // Additional context
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}

model PushSubscription {
  id             String    @id @default(cuid())
  userId         String?
  memberId        String?
  endpoint       String
  p256dh         String
  auth           String
  expirationTime DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  member         Member?   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@unique([memberId, endpoint])
  @@index([userId])
  @@index([memberId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  memberId  String?
  member    Member?  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  data      Json?    // Additional data (url, entityId, etc.)
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([memberId])
}

enum NotificationType {
  INFO
  WARNING
  EXPIRY_ALERT
  SETTLEMENT_READY
  DEPOSIT_CONFIRMED
  SYSTEM
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String   @default("general") // general, deposit, notification
  label     String?
  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Links members to products they can deposit
model MemberProduct {
  id          String   @id @default(cuid())
  memberId    String
  member      Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  isPrimary   Boolean  @default(false) // Primary product for this member
  createdAt   DateTime @default(now())

  @@unique([memberId, stockItemId])
  @@index([memberId])
  @@index([stockItemId])
}
