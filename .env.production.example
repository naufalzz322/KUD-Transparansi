# ============================================
# KUD Transparansi — Environment Variables
# Vercel Deployment Template
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env or .env.local to version control!

# ============================================
# DATABASE (PostgreSQL via Supabase)
# ============================================
# Get from: Supabase Dashboard > Settings > Database > Connection String
# Use the "Connection pooling" URL for better performance on serverless
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres"

# ============================================
# NextAuth Authentication
# ============================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="[GENERATE_A_SECURE_SECRET_KEY]"
NEXTAUTH_URL="https://[YOUR-VERCEL-APP].vercel.app"

# ============================================
# WhatsApp Notification (Fonnte)
# ============================================
# Get from: https://fonnte.com/dashboard
FONNTE_TOKEN="[YOUR_FONNTE_API_TOKEN]"

# Warehouse/Admin phone number for alerts (format: 08xxxxxxxxxx)
WAREHOUSE_PHONE="08xxxxxxxxxx"

# ============================================
# Push Notifications (Web Push / VAPID)
# ============================================
# Generate VAPID keys with:
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY="[GENERATED_VAPID_PUBLIC_KEY]"
VAPID_PRIVATE_KEY="[GENERATED_VAPID_PRIVATE_KEY]"
VAPID_SUBJECT="mailto:notify@[your-domain].com"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="[SAME_AS_VAPID_PUBLIC_KEY]"

# ============================================
# App Configuration
# ============================================
# The public URL of your app (no trailing slash)
NEXT_PUBLIC_APP_URL="https://[YOUR-VERCEL-APP].vercel.app"

# Cooperativa name displayed in the app
NEXT_PUBLIC_KOPERASI_NAME="KUD Sumber Makmur"

# ============================================
# Cron Job Security
# ============================================
# Generate with: openssl rand -hex 32
# Used to secure /api/cron/* endpoints
CRON_SECRET="[GENERATE_A_SECURE_RANDOM_STRING]"

# ============================================
# OPTIONAL: Email (Resend)
# ============================================
# Get from: https://resend.com/api-keys
# Only needed if you want email notifications
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================
# OPTIONAL: External Services
# ============================================
# QR Code Server (default: api.qrserver.com - no config needed)
# QR_CODE_API_URL="https://api.qrserver.com/v1/create-qr-code/"
